pkgname="wilburos-hyprland"
pkgver=1.3
pkgrel=1
pkgdesc='Wilburos Hyprland configuration'
arch=('any')
url="https://github.com/kildevaeld/wilburos-packages"
license=('GPL3')
depends=(
    'hyprland'
    'hypridle'
    'hyprlock'
    'hyprland-qt-support'
    'hyprlauncher'
    'hyprcursor'
    'hyprshutdown'
    'hyprpolkitagent'
    'xdg-desktop-portal-hyprland'
    'waybar'
    'otf-font-awesome'
    'wl-clipboard'
    # Network
    'nm-connection-editor'
    'network-manager-applet'
    # Bluetooth
    'blueman'
    # Apps
    'firefox'
    'kitty'
    ## File Manager
    'thunar'
    'thunar-archive-plugin'
    'thunar-volman'
    'thunar-vcs-plugin'
    'thunar-shares-plugin'

    'ttf-firacode-nerd'
)

prepare() {
    cp -af ../data/. "$srcdir"
}

package() {
    local _configdir="$pkgdir"/etc/skel/.config
    local _hydir="$_configdir"/hypr

    mkdir -p $_hydir

    cp -r "$srcdir"/.config/hypr/* $_hydir
}